# Supabase frontend (public anon credentials)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Supabase Edge Function openrouter-chat (server/CI only, never VITE_)
OPENROUTER_API_KEY=
ALLOWED_ORIGINS=https://upfunnel.click,https://app.upfunnel.click,http://localhost:5173

# Academia: Worker que firma subidas a R2
VITE_R2_PRESIGN_URL=https://tu-worker.workers.dev

# URL publica para reproducir medios de academia
VITE_ACADEMY_MEDIA_URL=https://tu-worker-media.workers.dev/?key=

# Scripts Node (solo en .env.local, sin VITE_)
UPLOAD_SCRIPT_ADMIN_EMAIL=
UPLOAD_SCRIPT_ADMIN_PASSWORD=

# R2 para scripts/upload_video.mjs y workers
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_BUCKET_NAME=upfunnel-academy
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
MAX_UPLOAD_BYTES=536870912

# Supabase servidor/CI, nunca en frontend
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# MCP local (mcp-supabase-custom), nunca commitear valores reales
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.TU_PROYECTO.supabase.co:5432/postgres
