# Supabase (obligatorio)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Asistente Gemini (opcional; expuesta en el bundle del navegador)
VITE_GOOGLE_GEMINI_API_KEY=

# Asistente OpenRouter (obligatorio; expuesta en el bundle del navegador)
VITE_OPENROUTER_API_KEY=


# Academia: Worker que firma subidas a R2 (obligatorio para subir vídeos/miniaturas)
# Despliega workers/r2-presign.js en Cloudflare y pega la URL aquí
VITE_R2_PRESIGN_URL=https://tu-worker.workers.dev

# URL pública para reproducir medios de academia (worker de streaming existente)
VITE_ACADEMY_MEDIA_URL=https://rough-silence-cf74.arvilladigital12.workers.dev/?key=

# Solo desarrollo: emails extra tratados como admin (separados por coma). En producción déjalo vacío.
VITE_BOOTSTRAP_ADMIN_EMAILS=

# Scripts Node (upload-agents.js, announce_updates.js) — solo en .env.local, sin VITE_
UPLOAD_SCRIPT_ADMIN_EMAIL=
UPLOAD_SCRIPT_ADMIN_PASSWORD=
