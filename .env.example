# R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# SUPABASE_SERVICE_ROLE_KEY=   # solo en servidor/CI, nunca en el frontend

# MCP local (mcp-supabase-custom) — NUNCA commitear valores reales
